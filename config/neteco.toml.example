# NetEco NBI Poller config — copy to config/neteco.toml and fill in credentials.
# Env vars override: NETECO_URL, NETECO_USER, NETECO_PASSWORD, DATABASE_URL

[neteco]
url = "https://10.10.0.3:31943"
user = "alarmi_nbi"
password = ""
# ca_cert_path = "/etc/ssl/neteco/neteco-ca.crt"    # optional: path to NetEco CA PEM
# danger_accept_invalid_certs = false                # dev only, never in production

[database]
dsn = "host=localhost port=5432 user=bht password=bht_dev_pw dbname=alarms"

[intervals]
topology_secs = 21600   # 6 hours
metrics_secs = 300      # 5 minutes
alarms_secs = 120       # 2 minutes

# After running --fingerprint, add key maps here to translate REST dataItemMap
# keys to our column names. Format: column_name = "rest_key_name"
# If a column name matches the REST key, no entry needed.
#
# [key_maps.site_unit]
# indoor_temp_c = "indoor_temperature"
# outdoor_temp_c = "outdoor_temperature"
# indoor_humidity_pct = "indoor_humidity"
#
# [key_maps.power_system]
# dc_output_voltage_v = "dc_output_voltage"
